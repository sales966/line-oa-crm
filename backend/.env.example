# LINE OA 客户进度中枢 backend 环境变量(复制为 .env 后填写)

# OpenAI API Key(留空则 /api/summarize 回 503「LLM 未配置」)
OPENAI_API_KEY=

# 监听端口(契约默认 4680)
PORT=4680

# LLM 模型(默认 gpt-5.5)
LLM_MODEL=

# 日志级别(可选:info / debug / warn)
# LOG_LEVEL=info

# 初始 admin 密码(仅 users 表为空、首次启动种子时生效;默认 admin123,登入后请立即修改)
ADMIN_INITIAL_PASSWORD=

# 插件采集 Token(/api/ingest/* 检查 header X-Extension-Token)——**必填**。
# 留空 = fail-closed:/api/ingest/* 全部回 401(局域网部署下这是必须的,否则任何
# 未认证客户端都能写库/落盘/触发 LLM)。填一串随机值后插件 options 需填相同 Token。
EXTENSION_TOKEN=

# 仅首次引导用:EXTENSION_TOKEN 未设时,设 ALLOW_UNAUTH_INGEST=1 可临时放行 /api/ingest/*
# (无任何认证,危险);设好 EXTENSION_TOKEN 后请移除本项。
# ALLOW_UNAUTH_INGEST=
